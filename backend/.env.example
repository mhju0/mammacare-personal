# ── Database ──────────────────────────────
DATABASE_URL=

# ── JWT ───────────────────────────────────
JWT_SECRET_KEY=
JWT_ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=
REFRESH_TOKEN_EXPIRE_DAYS=

# ── App ───────────────────────────────────
# development / production
APP_ENV=
DEBUG=
APP_HOST=
APP_PORT=

# ── Storage (사진 업로드용) ────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=
AZURE_CONTENT_SAFETY_ENDPOINT=
AZURE_CONTENT_SAFETY_KEY=
AZURE_CONTENT_SAFETY_API_VERSION=2024-09-01
AZURE_CONTENT_SAFETY_REJECT_SEVERITY=4

# ── OpenAI (ChatGPT 4o) ────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_DEPLOYMENT_NAME=

# ── Azure AI Language (날짜/시간 NER) ──
AZURE_LANGUAGE_ENDPOINT=
AZURE_LANGUAGE_KEY=

# ── CORS ──────────────────────────────────
ALLOWED_ORIGINS=

#------- OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

#------- OAuth — Kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=
KAKAO_MAP_REST_API_KEY=

#------- OAuth — Naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=

# ── Firebase Cloud Messaging ───────────────
# docker-compose 사용 시 프로젝트 루트의 firebase_credentials.json을 마운트합니다.
FIREBASE_CREDENTIALS_PATH=/app/firebase_credentials.json
